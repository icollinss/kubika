// Kubika ERP - Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Company ─────────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String   @default("Angola")
  currency    String   @default("AOA")
  taxId       String?  // NIF (Angola tax ID)
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

// ─── Auth (NextAuth v5 compatible) ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id])

  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Contacts ────────────────────────────────────────────────────────────────

model Contact {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  country   String      @default("Angola")
  taxId     String?     // NIF
  whatsapp  String?     // WhatsApp phone number (with country code, e.g. +244912345678)
  notes     String?
  type            ContactType @default(CUSTOMER)
  creditLimit     Float       @default(0)   // 0 = no limit
  creditTermsDays Int         @default(30)  // payment terms in days
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  companyId String

  salesOrders     SalesOrder[]
  invoices        Invoice[]
  purchaseOrders  PurchaseOrder[]
  supplierBills   SupplierBill[]
  posOrders       PosOrder[]     @relation("PosOrderCustomer")
  serviceOrders   ServiceOrder[] @relation("ServiceOrderCustomer")
}

// ─── Inventory: Units of Measure ─────────────────────────────────────────────

model UnitOfMeasure {
  id         String   @id @default(cuid())
  name       String   // e.g. "Kilogram"
  symbol     String   // e.g. "kg"
  category   String   // e.g. "Weight", "Volume", "Unit"
  ratio      Float    @default(1.0) // ratio to base unit
  isBase     Boolean  @default(false)
  companyId  String
  createdAt  DateTime @default(now())

  products         Product[]
  purchaseUomProds Product[] @relation("PurchaseUom")
}

// ─── Inventory: Product Categories ───────────────────────────────────────────

model ProductCategory {
  id          String            @id @default(cuid())
  name        String
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")
  companyId   String
  createdAt   DateTime          @default(now())

  products    Product[]
}

// ─── Inventory: Product Attributes (for variants) ────────────────────────────

model ProductAttribute {
  id        String                   @id @default(cuid())
  name      String                   // e.g. "Color", "Size"
  companyId String
  values    ProductAttributeValue[]
}

model ProductAttributeValue {
  id          String           @id @default(cuid())
  value       String           // e.g. "Red", "XL"
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  variantLines ProductVariantLine[]
}

// ─── Inventory: Products ──────────────────────────────────────────────────────

model Product {
  id              String          @id @default(cuid())
  name            String
  description     String?
  sku             String?
  barcode         String?
  internalRef     String?
  image           String?

  // Pricing
  salePrice       Float           @default(0)
  costPrice       Float           @default(0)
  currency        String          @default("AOA")

  // Classification
  categoryId      String?
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  productType     ProductType     @default(STORABLE)
  trackingType    TrackingType    @default(NONE)
  costingMethod   CostingMethod   @default(AVERAGE_COST)

  // Units
  uomId           String?
  uom             UnitOfMeasure?  @relation(fields: [uomId], references: [id])
  purchaseUomId   String?
  purchaseUom     UnitOfMeasure?  @relation("PurchaseUom", fields: [purchaseUomId], references: [id])

  // Stock config
  reorderPoint    Float           @default(0)
  reorderQty      Float           @default(0)
  leadTimeDays    Int             @default(0)

  // Flags
  canBeSold       Boolean         @default(true)
  canBePurchased  Boolean         @default(true)
  isArchived      Boolean         @default(false)

  companyId       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  variants        ProductVariant[]
  stockMoves      StockMove[]
  lots            Lot[]
  serials         SerialNumber[]
  salesLines      SalesOrderLine[]
  invoiceLines    InvoiceLine[]
  purchaseLines   PurchaseOrderLine[]
  billLines       SupplierBillLine[]
  posLines        PosOrderLine[]     @relation("PosLineProduct")
  serviceParts    ServicePart[]      @relation("ServicePartProduct")
}

// ─── Inventory: Product Variants ─────────────────────────────────────────────

model ProductVariant {
  id          String               @id @default(cuid())
  productId   String
  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String?
  barcode     String?
  salePrice   Float?
  costPrice   Float?
  image       String?
  isArchived  Boolean              @default(false)
  createdAt   DateTime             @default(now())

  lines       ProductVariantLine[]
  stockMoves  StockMove[]
}

model ProductVariantLine {
  id          String                @id @default(cuid())
  variantId   String
  variant     ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  valueId     String
  value       ProductAttributeValue @relation(fields: [valueId], references: [id])
}

// ─── Inventory: Warehouses & Locations ───────────────────────────────────────

model Warehouse {
  id          String     @id @default(cuid())
  name        String
  shortCode   String     // e.g. "LDA" for Luanda
  address     String?
  companyId   String
  createdAt   DateTime   @default(now())

  locations   Location[]
}

model Location {
  id          String       @id @default(cuid())
  name        String
  fullPath    String?      // e.g. "LDA/Stock/Shelf A"
  locationType LocationType @default(INTERNAL)
  warehouseId String?
  warehouse   Warehouse?   @relation(fields: [warehouseId], references: [id])
  parentId    String?
  parent      Location?    @relation("LocationTree", fields: [parentId], references: [id])
  children    Location[]   @relation("LocationTree")
  companyId   String
  createdAt   DateTime     @default(now())

  movesFrom   StockMove[]  @relation("MoveFrom")
  movesTo     StockMove[]  @relation("MoveTo")
}

// ─── Inventory: Lots & Serials ────────────────────────────────────────────────

model Lot {
  id          String     @id @default(cuid())
  lotNumber   String
  expiryDate  DateTime?
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  companyId   String
  createdAt   DateTime   @default(now())

  stockMoves  StockMove[]

  @@unique([lotNumber, productId, companyId])
}

model SerialNumber {
  id          String     @id @default(cuid())
  serial      String
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  companyId   String
  createdAt   DateTime   @default(now())

  stockMoves  StockMove[]

  @@unique([serial, productId, companyId])
}

// ─── Inventory: Stock Moves ───────────────────────────────────────────────────

model StockMove {
  id              String          @id @default(cuid())
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  fromLocationId  String?
  fromLocation    Location?       @relation("MoveFrom", fields: [fromLocationId], references: [id])
  toLocationId    String?
  toLocation      Location?       @relation("MoveTo", fields: [toLocationId], references: [id])
  lotId           String?
  lot             Lot?            @relation(fields: [lotId], references: [id])
  serialId        String?
  serial          SerialNumber?   @relation(fields: [serialId], references: [id])
  quantity        Float
  unitCost        Float           @default(0)
  moveType        StockMoveType
  reference       String?         // e.g. PO/001, SO/001
  note            String?
  movedAt         DateTime        @default(now())
  companyId       String
  createdAt       DateTime        @default(now())
}

// ─── Sales ───────────────────────────────────────────────────────────────────

model SalesOrder {
  id            String          @id @default(cuid())
  number        String          // e.g. SO/2026/001
  status        SalesStatus     @default(QUOTATION)
  customerId    String
  customer      Contact         @relation(fields: [customerId], references: [id])
  orderDate     DateTime        @default(now())
  expiryDate    DateTime?
  deliveryDate  DateTime?
  currency      String          @default("AOA")
  notes         String?
  termsAndConds String?

  // Totals (computed & stored for performance)
  subtotal      Float           @default(0)
  taxAmount     Float           @default(0)
  discountAmount Float          @default(0)
  total         Float           @default(0)

  companyId     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  lines         SalesOrderLine[]
  invoices      Invoice[]
}

model SalesOrderLine {
  id            String      @id @default(cuid())
  orderId       String
  order         SalesOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  description   String?
  quantity      Float
  unitPrice     Float
  discount      Float       @default(0) // percentage
  taxRate       Float       @default(14) // IVA 14% default
  subtotal      Float       @default(0)
  total         Float       @default(0)
  sequence      Int         @default(0)
  analyticAccountId String?
  analyticAccount   AnalyticAccount? @relation("SalesLineAnalytic", fields: [analyticAccountId], references: [id])
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  number        String        // e.g. FT/2026/001
  status        InvoiceStatus @default(DRAFT)
  orderId       String?
  order         SalesOrder?   @relation(fields: [orderId], references: [id])
  customerId    String
  customer      Contact       @relation(fields: [customerId], references: [id])
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?
  currency      String        @default("AOA")
  notes         String?

  subtotal      Float         @default(0)
  taxAmount     Float         @default(0)
  discountAmount Float        @default(0)
  total         Float         @default(0)
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)

  companyId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines         InvoiceLine[]
  payments      Payment[]
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  description String?
  quantity    Float
  unitPrice   Float
  discount    Float    @default(0)
  taxRate     Float    @default(14)
  subtotal    Float    @default(0)
  total       Float    @default(0)
  sequence    Int      @default(0)
  analyticAccountId String?
  analyticAccount   AnalyticAccount? @relation("InvoiceLineAnalytic", fields: [analyticAccountId], references: [id])
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  amount        Float
  currency      String        @default("AOA")
  method        PaymentMethod @default(CASH)
  reference     String?
  paidAt        DateTime      @default(now())
  notes         String?
  companyId     String
  createdAt     DateTime      @default(now())
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum ContactType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum ProductType {
  STORABLE     // tracked in stock
  CONSUMABLE   // not tracked
  SERVICE      // no physical stock
}

enum TrackingType {
  NONE
  LOT
  SERIAL
}

enum CostingMethod {
  STANDARD_PRICE
  AVERAGE_COST
  FIFO
}

enum LocationType {
  INTERNAL
  VENDOR
  CUSTOMER
  VIRTUAL
  TRANSIT
}

enum StockMoveType {
  RECEIPT       // incoming from supplier
  DELIVERY      // outgoing to customer
  INTERNAL      // between locations
  ADJUSTMENT    // inventory correction
  RETURN        // customer return
  SCRAP         // write-off
}

enum SalesStatus {
  QUOTATION     // draft quote
  CONFIRMED     // sales order confirmed
  DELIVERED     // goods delivered
  CANCELLED     // cancelled
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY   // e.g. Multicaixa Express
  CHECK
  CREDIT
}

// ─── Purchasing ───────────────────────────────────────────────────────────────

model PurchaseOrder {
  id            String          @id @default(cuid())
  number        String          // e.g. PO/2026/001
  status        PurchaseStatus  @default(DRAFT)
  supplierId    String
  supplier      Contact         @relation(fields: [supplierId], references: [id])
  orderDate     DateTime        @default(now())
  expectedDate  DateTime?
  currency      String          @default("AOA")
  notes         String?

  subtotal      Float           @default(0)
  taxAmount     Float           @default(0)
  total         Float           @default(0)

  companyId     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  lines         PurchaseOrderLine[]
  bills         SupplierBill[]
}

model PurchaseOrderLine {
  id            String        @id @default(cuid())
  orderId       String
  order         PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  description   String?
  quantity      Float
  unitPrice     Float
  taxRate       Float         @default(14)
  subtotal      Float         @default(0)
  total         Float         @default(0)
  qtyReceived   Float         @default(0)
  sequence      Int           @default(0)
  analyticAccountId String?
  analyticAccount   AnalyticAccount? @relation("POLineAnalytic", fields: [analyticAccountId], references: [id])
}

// ─── Supplier Bills ───────────────────────────────────────────────────────────

model SupplierBill {
  id            String      @id @default(cuid())
  number        String      // e.g. VB/2026/001
  status        BillStatus  @default(DRAFT)
  orderId       String?
  order         PurchaseOrder? @relation(fields: [orderId], references: [id])
  supplierId    String
  supplier      Contact     @relation(fields: [supplierId], references: [id])
  billDate      DateTime    @default(now())
  dueDate       DateTime?
  currency      String      @default("AOA")
  notes         String?

  subtotal      Float       @default(0)
  taxAmount     Float       @default(0)
  total         Float       @default(0)
  amountPaid    Float       @default(0)
  amountDue     Float       @default(0)

  companyId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lines         SupplierBillLine[]
  payments      BillPayment[]
}

model SupplierBillLine {
  id          String       @id @default(cuid())
  billId      String
  bill        SupplierBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  description String?
  quantity    Float
  unitPrice   Float
  taxRate     Float        @default(14)
  subtotal    Float        @default(0)
  total       Float        @default(0)
  sequence    Int          @default(0)
  analyticAccountId String?
  analyticAccount   AnalyticAccount? @relation("BillLineAnalytic", fields: [analyticAccountId], references: [id])
}

model BillPayment {
  id        String        @id @default(cuid())
  billId    String
  bill      SupplierBill  @relation(fields: [billId], references: [id])
  amount    Float
  currency  String        @default("AOA")
  method    PaymentMethod @default(CASH)
  reference String?
  paidAt    DateTime      @default(now())
  notes     String?
  companyId String
  createdAt DateTime      @default(now())
}

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum BillStatus {
  DRAFT
  CONFIRMED
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

// ─── Accounting: Chart of Accounts ───────────────────────────────────────────

model LedgerAccount {
  id            String      @id @default(cuid())
  code          String      // e.g. "1100", "3100"
  name          String      // e.g. "Cash", "Revenue from Sales"
  type          AccountType
  subtype       String?     // e.g. "Current Asset", "Fixed Asset"
  description   String?
  parentId      String?
  parent        LedgerAccount?    @relation("AccountTree", fields: [parentId], references: [id])
  children      LedgerAccount[]   @relation("AccountTree")
  isActive      Boolean     @default(true)
  allowReconciliation Boolean @default(false)
  currency      String      @default("AOA")
  companyId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  debitLines    JournalEntryLine[] @relation("DebitAccount")
  creditLines   JournalEntryLine[] @relation("CreditAccount")
}

// ─── Accounting: Journal Entries ──────────────────────────────────────────────

model JournalEntry {
  id          String             @id @default(cuid())
  number      String             // e.g. JE/2026/001
  date        DateTime           @default(now())
  description String
  reference   String?            // SO/001, PO/001, etc.
  entryType   JournalEntryType   @default(MANUAL)
  status      JournalStatus      @default(DRAFT)
  companyId   String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  lines       JournalEntryLine[]
}

model JournalEntryLine {
  id            String       @id @default(cuid())
  entryId       String
  entry         JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  debitAccountId  String?
  debitAccount    LedgerAccount?   @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId String?
  creditAccount   LedgerAccount?   @relation("CreditAccount", fields: [creditAccountId], references: [id])
  amount        Float
  description   String?
  sequence      Int          @default(0)
  analyticAccountId String?
  analyticAccount   AnalyticAccount? @relation(fields: [analyticAccountId], references: [id])
}

// ─── Accounting: Tax Entries ──────────────────────────────────────────────────

model TaxEntry {
  id          String    @id @default(cuid())
  taxType     TaxType
  rate        Float
  baseAmount  Float
  taxAmount   Float
  period      String    // e.g. "2026-03" (year-month)
  reference   String?   // invoice/bill number
  companyId   String
  createdAt   DateTime  @default(now())
}

// ─── Accounting Enums ─────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryType {
  MANUAL
  SALE
  PURCHASE
  PAYMENT
  RECEIPT
  ADJUSTMENT
  DEPRECIATION
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum TaxType {
  IVA        // Imposto sobre Valor Acrescentado (VAT 14%)
  IRT        // Imposto sobre Rendimento do Trabalho
  II         // Imposto Industrial
  IS         // Imposto de Selo
}

// ─── Projects & Analytic Accounting ──────────────────────────────────────────

model AnalyticAccount {
  id          String   @id @default(cuid())
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects           Project[]
  journalLines       JournalEntryLine[]
  expenses           ProjectExpense[]
  salesOrderLines    SalesOrderLine[]   @relation("SalesLineAnalytic")
  invoiceLines       InvoiceLine[]      @relation("InvoiceLineAnalytic")
  purchaseOrderLines PurchaseOrderLine[] @relation("POLineAnalytic")
  supplierBillLines  SupplierBillLine[] @relation("BillLineAnalytic")
}

model Project {
  id               String        @id @default(cuid())
  name             String
  description      String?
  reference        String?       // e.g. PRJ/2026/001
  status           ProjectStatus @default(DRAFT)
  priority         Priority      @default(MEDIUM)
  startDate        DateTime?
  endDate          DateTime?
  budget           Float         @default(0)
  currency         String        @default("AOA")
  managerId        String?       // Employee id
  analyticAccountId String?
  analyticAccount  AnalyticAccount? @relation(fields: [analyticAccountId], references: [id])
  companyId        String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  milestones   ProjectMilestone[]
  tasks        ProjectTask[]
  expenses     ProjectExpense[]
  timesheets   Timesheet[]
}

model ProjectMilestone {
  id          String            @id @default(cuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  dueDate     DateTime?
  isDone      Boolean           @default(false)
  doneAt      DateTime?
  sequence    Int               @default(0)
  companyId   String
  createdAt   DateTime          @default(now())

  tasks       ProjectTask[]
}

model ProjectTask {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId String?
  milestone   ProjectMilestone? @relation(fields: [milestoneId], references: [id])
  title       String
  description String?
  status      TaskStatus  @default(TODO)
  priority    Priority    @default(MEDIUM)
  assigneeId  String?     // Employee id
  dueDate     DateTime?
  estimatedHours Float    @default(0)
  sequence    Int         @default(0)
  companyId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  timesheets  Timesheet[]
}

model Timesheet {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id])
  taskId      String?
  task        ProjectTask? @relation(fields: [taskId], references: [id])
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  date        DateTime
  hours       Float
  description String?
  companyId   String
  createdAt   DateTime    @default(now())
}

model ProjectExpense {
  id               String          @id @default(cuid())
  projectId        String
  project          Project         @relation(fields: [projectId], references: [id])
  analyticAccountId String?
  analyticAccount  AnalyticAccount? @relation(fields: [analyticAccountId], references: [id])
  description      String
  amount           Float
  date             DateTime        @default(now())
  category         String?         // e.g. "Labour", "Materials", "Travel"
  reference        String?         // Journal entry number
  companyId        String
  createdAt        DateTime        @default(now())
}

// ─── Project Enums ────────────────────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── HR Models ────────────────────────────────────────────────────────────────

model Department {
  id          String     @id @default(cuid())
  name        String
  description String?
  companyId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employees   Employee[]
}

model Employee {
  id            String         @id @default(cuid())
  employeeNumber String        @unique
  firstName     String
  lastName      String
  email         String?
  phone         String?
  nif           String?        // Angola tax ID
  inssNumber    String?        // Social security number
  dateOfBirth   DateTime?
  hireDate      DateTime
  endDate       DateTime?
  status        EmployeeStatus @default(ACTIVE)
  jobTitle      String?
  departmentId  String?
  department    Department?    @relation(fields: [departmentId], references: [id])
  companyId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  contracts     Contract[]
  attendances   Attendance[]
  payslips      Payslip[]
  timesheets    Timesheet[]
  serviceOrders ServiceOrder[] @relation("ServiceTechnician")
}

model Contract {
  id            String         @id @default(cuid())
  employeeId    String
  employee      Employee       @relation(fields: [employeeId], references: [id])
  contractType  ContractType   @default(PERMANENT)
  startDate     DateTime
  endDate       DateTime?
  basicSalary   Float          // Base salary in AOA
  allowances    Float          @default(0)   // Transport, food, etc.
  currency      String         @default("AOA")
  workingHours  Float          @default(8)   // per day
  status        ContractStatus @default(ACTIVE)
  notes         String?
  companyId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Attendance {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  hoursWorked Float     @default(0)
  status      AttendanceStatus @default(PRESENT)
  note        String?
  companyId   String
  createdAt   DateTime  @default(now())

  @@unique([employeeId, date])
}

model Payslip {
  id            String        @id @default(cuid())
  number        String        // PS/2026/001
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id])
  period        String        // "2026-03"
  basicSalary   Float
  allowances    Float         @default(0)
  grossSalary   Float
  inssEmployee  Float         @default(0)   // 3% employee INSS
  inssEmployer  Float         @default(0)   // 8% employer INSS
  irtAmount     Float         @default(0)   // IRT tax
  otherDeductions Float       @default(0)
  netSalary     Float
  status        PayslipStatus @default(DRAFT)
  paidAt        DateTime?
  companyId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines         PayslipLine[]
}

model PayslipLine {
  id          String   @id @default(cuid())
  payslipId   String
  payslip     Payslip  @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  type        String   // "EARNING" | "DEDUCTION"
  label       String
  amount      Float
  sequence    Int      @default(0)
}

// ─── HR Enums ─────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

enum ContractType {
  PERMANENT
  FIXED_TERM
  PART_TIME
  INTERN
  CONSULTANT
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum PayslipStatus {
  DRAFT
  CONFIRMED
  PAID
}

// ─── POS ─────────────────────────────────────────────────────────────────────

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum PosOrderStatus {
  PAID
  REFUNDED
  CANCELLED
}

model PosConfig {
  id             String       @id @default(cuid())
  name           String       // e.g. "Main Counter", "Warehouse", "Express Lane"
  description    String?
  isActive       Boolean      @default(true)
  defaultTaxRate Float        @default(14)
  allowDiscount  Boolean      @default(false)
  sessions       PosSession[]
  companyId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model PosSession {
  id          String           @id @default(cuid())
  number      String
  configId    String
  config      PosConfig        @relation(fields: [configId], references: [id])
  status      PosSessionStatus @default(OPEN)
  openedAt    DateTime         @default(now())
  closedAt    DateTime?
  openingCash Float            @default(0)
  closingCash Float?
  cashSales   Float            @default(0)
  notes       String?
  orders      PosOrder[]
  companyId   String
  createdAt   DateTime         @default(now())
}

model PosOrder {
  id             String         @id @default(cuid())
  number         String
  sessionId      String
  session        PosSession     @relation(fields: [sessionId], references: [id])
  status         PosOrderStatus @default(PAID)
  lines          PosOrderLine[]
  subtotal       Float          @default(0)
  taxAmount      Float          @default(0)
  total          Float          @default(0)
  paymentMethod  PaymentMethod  @default(CASH)
  amountReceived Float          @default(0)
  change         Float          @default(0)
  customerId     String?
  customer       Contact?       @relation("PosOrderCustomer", fields: [customerId], references: [id])
  notes          String?
  companyId      String
  createdAt      DateTime       @default(now())
}

model PosOrderLine {
  id          String    @id @default(cuid())
  orderId     String
  order       PosOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation("PosLineProduct", fields: [productId], references: [id])
  description String?
  quantity    Float
  unitPrice   Float
  taxRate     Float     @default(14)
  subtotal    Float     @default(0)
  total       Float     @default(0)
}

// ─── Field Service ────────────────────────────────────────────────────────────

enum ServiceOrderStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServicePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model WorksheetTemplate {
  id        String         @id @default(cuid())
  name      String
  fields    Json           // [{ id, label, type: text|textarea|number|checkbox|select, required, options? }]
  companyId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  orders    ServiceOrder[]
}

model ServiceOrder {
  id            String             @id @default(cuid())
  number        String
  title         String
  description   String?
  status        ServiceOrderStatus @default(DRAFT)
  priority      ServicePriority    @default(NORMAL)
  customerId    String
  customer      Contact            @relation("ServiceOrderCustomer", fields: [customerId], references: [id])
  technicianId  String?
  technician    Employee?          @relation("ServiceTechnician", fields: [technicianId], references: [id])
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  address       String?
  latitude      Float?
  longitude     Float?
  worksheetId   String?
  worksheet     WorksheetTemplate? @relation(fields: [worksheetId], references: [id])
  worksheetData Json?
  signature     String?
  notes         String?
  parts         ServicePart[]
  companyId     String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model ServicePart {
  id        String       @id @default(cuid())
  orderId   String
  order     ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation("ServicePartProduct", fields: [productId], references: [id])
  quantity  Float
  unitCost  Float        @default(0)
}

// ─── Payment Providers ───────────────────────────────────────────────────────

model PaymentConfig {
  id            String   @id @default(cuid())
  provider      String   // FLUTTERWAVE | PAYSTACK | DPO | MULTICAIXA
  publicKey     String?
  secretKey     String
  webhookSecret String?
  isActive      Boolean  @default(false)
  currency      String   @default("USD") // preferred charge currency for this provider
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  links         PaymentLink[]

  @@unique([provider, companyId])
}

model PaymentLink {
  id          String    @id @default(cuid())
  invoiceId   String
  provider    String
  configId    String
  config      PaymentConfig @relation(fields: [configId], references: [id])
  linkUrl     String
  txRef       String    @unique
  amount      Float
  currency    String
  status      String    @default("PENDING") // PENDING | PAID | FAILED
  paidAt      DateTime?
  companyId   String
  createdAt   DateTime  @default(now())
}

// ─── Multi-Currency: Exchange Rates ──────────────────────────────────────────

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String   // e.g. "USD", "EUR"
  toCurrency   String   // always the company's base currency e.g. "AOA"
  rate         Float    // how many toCurrency units = 1 fromCurrency unit
  effectiveDate DateTime @default(now())
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([fromCurrency, toCurrency, companyId])   // latest rate per pair
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

enum LeadSource {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  TIKTOK
  YOUTUBE
  WHATSAPP
  WEBSITE
  REFERRAL
  MANUAL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

model Lead {
  id             String      @id @default(cuid())
  name           String
  email          String?
  phone          String?
  whatsapp       String?
  company        String?
  jobTitle       String?
  source         LeadSource  @default(MANUAL)
  status         LeadStatus  @default(NEW)
  expectedValue  Float?
  notes          String?
  assignedToId   String?     // User.id
  convertedToId  String?     // Contact.id once converted
  companyId      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  activities     LeadActivity[]
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   // NOTE | CALL | EMAIL | WHATSAPP | MEETING
  body      String
  companyId String
  createdAt DateTime @default(now())
}

// ─── WhatsApp Log ────────────────────────────────────────────────────────────

model WhatsappLog {
  id          String   @id @default(cuid())
  to          String   // phone number
  type        String   // INVOICE | QUOTATION | CUSTOM
  referenceId String   // invoice/SO id
  reference   String   // display number e.g. FT/2026/001
  body        String
  status      String   @default("SENT") // SENT | FAILED
  twilioSid   String?
  companyId   String
  sentAt      DateTime @default(now())
}
