// Kubika ERP - Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Company ─────────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String   @default("Angola")
  currency    String   @default("AOA")
  taxId       String?  // NIF (Angola tax ID)
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

// ─── Auth (NextAuth v5 compatible) ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id])

  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Contacts ────────────────────────────────────────────────────────────────

model Contact {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  country   String      @default("Angola")
  taxId     String?     // NIF
  notes     String?
  type      ContactType @default(CUSTOMER)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  companyId String

  salesOrders SalesOrder[]
  invoices    Invoice[]
}

// ─── Inventory: Units of Measure ─────────────────────────────────────────────

model UnitOfMeasure {
  id         String   @id @default(cuid())
  name       String   // e.g. "Kilogram"
  symbol     String   // e.g. "kg"
  category   String   // e.g. "Weight", "Volume", "Unit"
  ratio      Float    @default(1.0) // ratio to base unit
  isBase     Boolean  @default(false)
  companyId  String
  createdAt  DateTime @default(now())

  products         Product[]
  purchaseUomProds Product[] @relation("PurchaseUom")
}

// ─── Inventory: Product Categories ───────────────────────────────────────────

model ProductCategory {
  id          String            @id @default(cuid())
  name        String
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")
  companyId   String
  createdAt   DateTime          @default(now())

  products    Product[]
}

// ─── Inventory: Product Attributes (for variants) ────────────────────────────

model ProductAttribute {
  id        String                   @id @default(cuid())
  name      String                   // e.g. "Color", "Size"
  companyId String
  values    ProductAttributeValue[]
}

model ProductAttributeValue {
  id          String           @id @default(cuid())
  value       String           // e.g. "Red", "XL"
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  variantLines ProductVariantLine[]
}

// ─── Inventory: Products ──────────────────────────────────────────────────────

model Product {
  id              String          @id @default(cuid())
  name            String
  description     String?
  sku             String?
  barcode         String?
  internalRef     String?
  image           String?

  // Pricing
  salePrice       Float           @default(0)
  costPrice       Float           @default(0)
  currency        String          @default("AOA")

  // Classification
  categoryId      String?
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  productType     ProductType     @default(STORABLE)
  trackingType    TrackingType    @default(NONE)
  costingMethod   CostingMethod   @default(AVERAGE_COST)

  // Units
  uomId           String?
  uom             UnitOfMeasure?  @relation(fields: [uomId], references: [id])
  purchaseUomId   String?
  purchaseUom     UnitOfMeasure?  @relation("PurchaseUom", fields: [purchaseUomId], references: [id])

  // Stock config
  reorderPoint    Float           @default(0)
  reorderQty      Float           @default(0)
  leadTimeDays    Int             @default(0)

  // Flags
  canBeSold       Boolean         @default(true)
  canBePurchased  Boolean         @default(true)
  isArchived      Boolean         @default(false)

  companyId       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  variants        ProductVariant[]
  stockMoves      StockMove[]
  lots            Lot[]
  serials         SerialNumber[]
  salesLines      SalesOrderLine[]
  invoiceLines    InvoiceLine[]
}

// ─── Inventory: Product Variants ─────────────────────────────────────────────

model ProductVariant {
  id          String               @id @default(cuid())
  productId   String
  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String?
  barcode     String?
  salePrice   Float?
  costPrice   Float?
  image       String?
  isArchived  Boolean              @default(false)
  createdAt   DateTime             @default(now())

  lines       ProductVariantLine[]
  stockMoves  StockMove[]
}

model ProductVariantLine {
  id          String                @id @default(cuid())
  variantId   String
  variant     ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  valueId     String
  value       ProductAttributeValue @relation(fields: [valueId], references: [id])
}

// ─── Inventory: Warehouses & Locations ───────────────────────────────────────

model Warehouse {
  id          String     @id @default(cuid())
  name        String
  shortCode   String     // e.g. "LDA" for Luanda
  address     String?
  companyId   String
  createdAt   DateTime   @default(now())

  locations   Location[]
}

model Location {
  id          String       @id @default(cuid())
  name        String
  fullPath    String?      // e.g. "LDA/Stock/Shelf A"
  locationType LocationType @default(INTERNAL)
  warehouseId String?
  warehouse   Warehouse?   @relation(fields: [warehouseId], references: [id])
  parentId    String?
  parent      Location?    @relation("LocationTree", fields: [parentId], references: [id])
  children    Location[]   @relation("LocationTree")
  companyId   String
  createdAt   DateTime     @default(now())

  movesFrom   StockMove[]  @relation("MoveFrom")
  movesTo     StockMove[]  @relation("MoveTo")
}

// ─── Inventory: Lots & Serials ────────────────────────────────────────────────

model Lot {
  id          String     @id @default(cuid())
  lotNumber   String
  expiryDate  DateTime?
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  companyId   String
  createdAt   DateTime   @default(now())

  stockMoves  StockMove[]

  @@unique([lotNumber, productId, companyId])
}

model SerialNumber {
  id          String     @id @default(cuid())
  serial      String
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  companyId   String
  createdAt   DateTime   @default(now())

  stockMoves  StockMove[]

  @@unique([serial, productId, companyId])
}

// ─── Inventory: Stock Moves ───────────────────────────────────────────────────

model StockMove {
  id              String          @id @default(cuid())
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  fromLocationId  String?
  fromLocation    Location?       @relation("MoveFrom", fields: [fromLocationId], references: [id])
  toLocationId    String?
  toLocation      Location?       @relation("MoveTo", fields: [toLocationId], references: [id])
  lotId           String?
  lot             Lot?            @relation(fields: [lotId], references: [id])
  serialId        String?
  serial          SerialNumber?   @relation(fields: [serialId], references: [id])
  quantity        Float
  unitCost        Float           @default(0)
  moveType        StockMoveType
  reference       String?         // e.g. PO/001, SO/001
  note            String?
  movedAt         DateTime        @default(now())
  companyId       String
  createdAt       DateTime        @default(now())
}

// ─── Sales ───────────────────────────────────────────────────────────────────

model SalesOrder {
  id            String          @id @default(cuid())
  number        String          // e.g. SO/2026/001
  status        SalesStatus     @default(QUOTATION)
  customerId    String
  customer      Contact         @relation(fields: [customerId], references: [id])
  orderDate     DateTime        @default(now())
  expiryDate    DateTime?
  deliveryDate  DateTime?
  currency      String          @default("AOA")
  notes         String?
  termsAndConds String?

  // Totals (computed & stored for performance)
  subtotal      Float           @default(0)
  taxAmount     Float           @default(0)
  discountAmount Float          @default(0)
  total         Float           @default(0)

  companyId     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  lines         SalesOrderLine[]
  invoices      Invoice[]
}

model SalesOrderLine {
  id            String      @id @default(cuid())
  orderId       String
  order         SalesOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  description   String?
  quantity      Float
  unitPrice     Float
  discount      Float       @default(0) // percentage
  taxRate       Float       @default(14) // IVA 14% default
  subtotal      Float       @default(0)
  total         Float       @default(0)
  sequence      Int         @default(0)
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  number        String        // e.g. FT/2026/001
  status        InvoiceStatus @default(DRAFT)
  orderId       String?
  order         SalesOrder?   @relation(fields: [orderId], references: [id])
  customerId    String
  customer      Contact       @relation(fields: [customerId], references: [id])
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?
  currency      String        @default("AOA")
  notes         String?

  subtotal      Float         @default(0)
  taxAmount     Float         @default(0)
  discountAmount Float        @default(0)
  total         Float         @default(0)
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)

  companyId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lines         InvoiceLine[]
  payments      Payment[]
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  description String?
  quantity    Float
  unitPrice   Float
  discount    Float    @default(0)
  taxRate     Float    @default(14)
  subtotal    Float    @default(0)
  total       Float    @default(0)
  sequence    Int      @default(0)
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  amount        Float
  currency      String        @default("AOA")
  method        PaymentMethod @default(CASH)
  reference     String?
  paidAt        DateTime      @default(now())
  notes         String?
  companyId     String
  createdAt     DateTime      @default(now())
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum ContactType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum ProductType {
  STORABLE     // tracked in stock
  CONSUMABLE   // not tracked
  SERVICE      // no physical stock
}

enum TrackingType {
  NONE
  LOT
  SERIAL
}

enum CostingMethod {
  STANDARD_PRICE
  AVERAGE_COST
  FIFO
}

enum LocationType {
  INTERNAL
  VENDOR
  CUSTOMER
  VIRTUAL
  TRANSIT
}

enum StockMoveType {
  RECEIPT       // incoming from supplier
  DELIVERY      // outgoing to customer
  INTERNAL      // between locations
  ADJUSTMENT    // inventory correction
  RETURN        // customer return
  SCRAP         // write-off
}

enum SalesStatus {
  QUOTATION     // draft quote
  CONFIRMED     // sales order confirmed
  DELIVERED     // goods delivered
  CANCELLED     // cancelled
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY   // e.g. Multicaixa Express
  CHECK
  CREDIT
}
